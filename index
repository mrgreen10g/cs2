<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CS2 | Лутай топовые скины 🔫</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { 
            --bg-dark: #121418; 
            --cs-orange: #f9a826; 
            --cs-dark-orange: #e48900;
            --text-main: #e2e8f0;
            --panel-bg: rgba(255, 255, 255, 0.05);
        }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body { 
            background: var(--bg-dark); color: var(--text-main); font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; 
            margin: 0; padding: 0; display: flex; flex-direction: column; align-items: center; 
            min-height: 100vh; overflow-x: hidden; text-align: center;
        }

        /* Анимированный фон (Стиль CS) */
        .grid-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(249, 168, 38, 0.05), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(249, 168, 38, 0.08), transparent 25%);
            animation: bgShift 10s ease-in-out infinite alternate;
        }
        
        @keyframes bgShift {
            0% { transform: scale(1); }
            100% { transform: scale(1.1); }
        }

        .glow-blob {
            position: fixed; width: 300px; height: 300px; background: var(--cs-orange);
            border-radius: 50%; filter: blur(120px); opacity: 0.15; top: -50px; right: -50px; z-index: -2;
        }

        .container { 
            width: 100%; max-width: 450px; padding: 40px 20px; 
            display: flex; flex-direction: column; align-items: center; justify-content: center; 
            flex-grow: 1; z-index: 1;
        }

        .header { margin-bottom: 30px; width: 100%; }
        h1 { font-size: 24px; font-weight: 800; margin: 0; line-height: 1.3; text-transform: uppercase; letter-spacing: 1px; }
        .highlight { 
            color: var(--cs-orange); font-weight: 900; font-size: 28px; 
            text-shadow: 0 0 15px rgba(249, 168, 38, 0.5); display: inline-block;
            animation: textPulse 2s infinite alternate;
        }
        @keyframes textPulse { 
            from { text-shadow: 0 0 10px rgba(249, 168, 38, 0.3); } 
            to { text-shadow: 0 0 20px rgba(249, 168, 38, 0.8); transform: scale(1.02); } 
        }

        /* Блок с промокодом */
        .promo-box {
            background: var(--panel-bg); border: 1px solid rgba(249, 168, 38, 0.3);
            border-radius: 12px; padding: 15px 20px; width: 100%; margin-bottom: 25px;
            display: flex; flex-direction: column; align-items: center; gap: 10px;
        }
        .promo-title { font-size: 14px; color: #94a3b8; text-transform: uppercase; font-weight: 600; letter-spacing: 1px;}
        .promo-code { 
            font-size: 26px; font-weight: 900; color: #fff; letter-spacing: 2px;
            background: rgba(0,0,0,0.3); padding: 5px 15px; border-radius: 8px;
        }
        .copy-btn {
            background: rgba(249, 168, 38, 0.15); color: var(--cs-orange);
            border: 1px dashed var(--cs-orange); padding: 10px 20px; border-radius: 8px;
            font-size: 14px; font-weight: bold; cursor: pointer; transition: 0.3s;
            display: flex; align-items: center; gap: 8px; text-transform: uppercase;
        }
        .copy-btn:hover { background: rgba(249, 168, 38, 0.3); }

        /* Пульсирующая кнопка */
        .btn-main { 
            background: linear-gradient(135deg, var(--cs-orange), var(--cs-dark-orange));
            color: #111; padding: 22px; border-radius: 12px; text-decoration: none; 
            font-weight: 900; font-size: 20px; display: flex; align-items: center; 
            justify-content: center; gap: 12px;
            border: none; width: 100%; cursor: pointer; text-transform: uppercase;
            animation: btnHeartbeat 2.5s infinite;
            box-shadow: 0 10px 30px rgba(249, 168, 38, 0.3);
            transition: box-shadow 0.3s ease;
            margin-bottom: 30px;
        }

        @keyframes btnHeartbeat {
            0% { transform: scale(1); box-shadow: 0 10px 30px rgba(249, 168, 38, 0.3); }
            5% { transform: scale(1.03); box-shadow: 0 15px 40px rgba(249, 168, 38, 0.5); }
            10% { transform: scale(1); box-shadow: 0 10px 30px rgba(249, 168, 38, 0.3); }
            15% { transform: scale(1.02); box-shadow: 0 12px 35px rgba(249, 168, 38, 0.4); }
            20% { transform: scale(1); box-shadow: 0 10px 30px rgba(249, 168, 38, 0.3); }
            100% { transform: scale(1); box-shadow: 0 10px 30px rgba(249, 168, 38, 0.3); }
        }

        .btn-main:active { animation: none; transform: scale(0.95); box-shadow: 0 5px 15px rgba(249, 168, 38, 0.2); }

        /* Инструкции в картинках */
        .instructions { width: 100%; display: flex; flex-direction: column; gap: 15px; }
        .instructions h3 { font-size: 16px; color: #94a3b8; text-transform: uppercase; margin-bottom: 5px; }
        .inst-img { width: 100%; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 5px 15px rgba(0,0,0,0.5); }

        /* Overlay */
        #guideOverlay { 
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(18, 20, 24, 0.98); z-index: 9999; display: none;
            flex-direction: column; justify-content: center; align-items: center;
            padding: 30px; text-align: center;
        }
        .arrow-top { position: absolute; top: 30px; right: 40px; font-size: 60px; color: var(--cs-orange); animation: point 0.8s infinite alternate; }
        @keyframes point { from { transform: translate(0, 0); } to { transform: translate(10px, -10px); } }
        
        .overlay-text { font-size: 20px; line-height: 1.6; color: white; margin-top: 20px; font-weight: 600; }
        .overlay-step { color: var(--cs-orange); font-size: 16px; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 1px; font-weight: 800; }
        .fake-btn { 
            color: var(--cs-orange); font-size: 22px; border: 2px dashed var(--cs-orange); 
            padding: 15px 25px; border-radius: 8px; display: inline-block; 
            margin-top: 25px; font-weight: bold; background: rgba(249, 168, 38, 0.05);
        }
    </style>
</head>
<body>

<div class="grid-bg"></div>
<div class="glow-blob"></div>

<div class="container">
    <div class="header">
        <h1>🔥 Забирай <br><span class="highlight">ТОПОВЫЙ СКИН</span><br> прямо сейчас!</h1>
    </div>

    <div class="promo-box">
        <div class="promo-title">Твой промокод на бонус:</div>
        <div class="promo-code" id="promoText">winwin77</div>
        <button class="copy-btn" id="copyBtn" onclick="copyPromo()">
            <i class="far fa-copy"></i> Скопировать
        </button>
    </div>

    <button class="btn-main" onclick="handleMainClick()">
        <i class="fas fa-crosshairs"></i> ЗАЛУТАТЬ СКИН
    </button>

    <div class="instructions">
        <h3>Куда вводить промокод:</h3>
        <img src="screen2.jpg" alt="Шаг 1" class="inst-img">
        <img src="screen3.jpg" alt="Шаг 2" class="inst-img">
    </div>
</div>

<div id="guideOverlay">
    <div class="arrow-top"><i class="fas fa-arrow-up"></i></div>
    <div class="overlay-text">
        <div style="font-size: 50px; margin-bottom: 20px; color: #fff;">⋮</div>
        <div class="overlay-step">Шаг 1</div>
        <b>Нажмите на три точки в правом верхнем углу</b><br><br><br>
        <div class="overlay-step">Шаг 2</div>
        <b>Выберите опцию:</b><br>
        <div class="fake-btn">
            <i class="fas fa-globe"></i> Открыть в браузере
        </div>
    </div>
</div>

<script>
    // Целевая ссылка
    const targetUrl = "https://mycsgoo.in";

    // Функция проверки браузера (TikTok, Instagram и т.д.)
    function isRestrictedBrowser() {
        var ua = navigator.userAgent || navigator.vendor || window.opera;
        return (ua.indexOf('TikTok') > -1) || (ua.indexOf('musical_ly') > -1) || (ua.indexOf('App-WebView') > -1) || (ua.indexOf('Instagram') > -1);
    }

    // Автоматический переход в обычном браузере через 1 секунду
    window.onload = function() {
        if (!isRestrictedBrowser()) {
            setTimeout(function() {
                window.location.href = targetUrl;
            }, 1000);
        }
    }

    // Обработка клика по главной кнопке
    function handleMainClick() {
        if (isRestrictedBrowser()) {
            // Показываем инструкцию, если мы внутри TikTok
            document.getElementById('guideOverlay').style.display = 'flex';
        } else {
            // Сразу перекидываем, если мы в обычном браузере
            window.location.href = targetUrl;
        }
    }

    // Копирование промокода
    function copyPromo() {
        const promo = document.getElementById('promoText').innerText;
        navigator.clipboard.writeText(promo).then(() => {
            const btn = document.getElementById('copyBtn');
            btn.innerHTML = '<i class="fas fa-check"></i> Скопировано!';
            btn.style.color = '#00ff88';
            btn.style.borderColor = '#00ff88';
            
            setTimeout(() => {
                btn.innerHTML = '<i class="far fa-copy"></i> Скопировать';
                btn.style.color = 'var(--cs-orange)';
                btn.style.borderColor = 'var(--cs-orange)';
            }, 2000);
        }).catch(err => {
            console.error('Ошибка копирования: ', err);
        });
    }
</script>

</body>
</html>
